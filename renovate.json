{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "packageRules": [
    {
      "groupName": "React packages",
      "matchPackagePatterns": ["^react", "^@types/react"]
    },
    {
      "groupName": "HeroUI packages",
      "matchPackagePatterns": ["^@heroui/"]
    },
    {
      "groupName": "Tailwind CSS packages",
      "matchPackagePatterns": ["^tailwindcss", "^@tailwindcss/"]
    },
    {
      "groupName": "Vite packages",
      "matchPackagePatterns": ["^vite", "^@vitejs/"]
    },
    {
      "groupName": "ESLint packages",
      "matchPackagePatterns": ["^eslint", "^@eslint/"]
    },
    {
      "groupName": "TypeScript and type definitions",
      "matchPackagePatterns": ["^typescript$", "^@typescript-eslint/", "^@types/"]
    },
    {
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true
    }
  ]
}
